packages/web/.claude-internal/

# Standalone build artifacts — keep _standalone/ in npm for zero-build install.
# Only exclude node_modules symlinks (standalone has its own traced deps).
!_standalone/
_standalone/node_modules/node_modules

# MCP package build artifacts
packages/*/*/.turbo/
packages/*/*/tsconfig.tsbuildinfo
packages/protocols/acp/src/*.test.ts
packages/protocols/acp/node_modules/
packages/foundation/permissions/src/*.test.ts
packages/foundation/permissions/node_modules/
packages/mindos/src/*.test.ts
packages/mindos/node_modules/
packages/protocols/mcp-server/node_modules/
packages/protocols/mcp-server/*.tgz

# Assets dev files
assets/node_modules/
assets/package-lock.json
assets/package.json
assets/capture-demo.mjs
assets/demo-flow.html
assets/demo-flow-zh.html
assets/images/

# Mobile (not part of npm package)
packages/mobile/

# Desktop (not part of npm package)
packages/desktop/
packages/desktop-tauri/

